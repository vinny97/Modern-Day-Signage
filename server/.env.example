# Copy to server/.env and fill in real secrets locally.
DATABASE_URL='postgresql://postgres.jkbtfzmebgjzmjapsdmz:<YOUR-PASSWORD>@aws-1-eu-central-2.pooler.supabase.com:6543/postgres'
PGSSL=true
PG_POOL_MAX=3

# Object storage. Leave local for development; R2 uses Cloudflare's S3 API.
STORAGE_DRIVER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=
JWT_SECRET='<GENERATE-A-LONG-RANDOM-VALUE>'

# ScreenFizz Player one-time price in pence (defaults to £99).
HARDWARE_PLAYER_PRICE_PENCE=9900

# Transactional email. RESEND_FROM_EMAIL must use a domain verified in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=ScreenTinker
# RESEND_DEV_RESTRICT_TO=developer@example.com

# Keep this sqlite until runtime routes/services have been converted to Postgres.
DB_CLIENT=sqlite
