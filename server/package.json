{
  "name": "screentinker",
  "version": "1.9.1-beta3",
  "description": "ScreenTinker - Digital Signage Management Server",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --watch --env-file-if-exists=.env server.js",
    "test": "node --test",
    "db:pg:schema": "node ../scripts/build-postgres-schema.js",
    "db:pg:migrate": "node ../scripts/migrate-sqlite-to-postgres.js",
    "db:pg:verify": "node ../scripts/verify-postgres-import.js",
    "db:pg:verify-auth": "node ../scripts/verify-postgres-auth.js",
    "db:pg:verify-core": "node ../scripts/verify-postgres-core.js",
    "storage:r2:verify": "node ../scripts/verify-r2.js",
    "storage:r2:backfill": "node ../scripts/backfill-r2.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@azure/msal-node": "^5.2.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "otplib": "^12.0.1",
    "pg": "^8.22.0",
    "sharp": "^0.33.2",
    "socket.io": "^4.7.2",
    "stripe": "^20.4.1",
    "unzipper": "^0.12.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "js-yaml": "^4.2.0",
    "socket.io-client": "^4.8.3"
  }
}
